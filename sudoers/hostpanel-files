# File Manager plugin sudoers
# Allows the hostpanel service user to operate on files owned by hosting users.
# Core sudoers already grants: /usr/bin/tee *, /usr/bin/cat *, /usr/bin/mkdir -p *, /usr/bin/chmod 644 *
# This file adds the additional operations specific to the file manager.

# Move files/dirs across ownership boundaries (used by file manager move operation)
%hostpanel ALL=(root) NOPASSWD: /usr/bin/mv *

# Custom chmod wrapper that accepts arbitrary octal modes (used by file manager chmod operation)
%hostpanel ALL=(root) NOPASSWD: /opt/hostpanel/bin/hp-chmod *
